{
  "_comment": "Template for .mcp.json — copy to .mcp.json and replace AUTH_TOKEN with your real token. Or set the AUTH_TOKEN environment variable in your shell so the empty string in .mcp.json is overridden at runtime.",
  "mcpServers": {
    "agent_handler": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://agent-proxy.perplexity.ai/merge_mcp",
        "--header",
        "Authorization: Bearer ${AUTH_TOKEN}"
      ],
      "env": {
        "AUTH_TOKEN": "agp_REPLACE_WITH_YOUR_PERPLEXITY_AGENT_PROXY_TOKEN"
      }
    }
  }
}
