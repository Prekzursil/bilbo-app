<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules (Android 12+).
    Excludes sensitive local data from cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="bilbo.db" />
        <exclude domain="sharedpref" path="dev.bilbo.app_preferences.xml" />
        <exclude domain="sharedpref" path="supabase_session.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="bilbo.db" />
        <exclude domain="sharedpref" path="supabase_session.xml" />
    </device-transfer>
</data-extraction-rules>
